{
  "name": "kokkoro-bot",
  "version": "1.0.0",
  "description": "Discord BOT",
  "main": "index.js",
  "author": "Jin An",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^8.57.0",
    "prettier": "^3.8.3",
    "tsx": "^4.10.1",
    "typescript": "^5.4.5",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@google/genai": "^2.7.0",
    "axios": "^1.7.4",
    "better-sqlite3": "^12.10.0",
    "compromise": "^14.15.1",
    "discord.js": "^14.26.4",
    "forever": "^4.0.3",
    "mem0ai": "^3.0.6",
    "moment": "^2.30.1",
    "natural": "^8.1.1",
    "yahoo-finance2": "^3.15.2"
  },
  "scripts": {
    "dev": "npx tsx watch src/index.ts",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc",
    "start": "node dist/src/index.js",
    "start:bg": "forever start --append -l forever.log -o out.log -e err.log dist/src/index.js",
    "stop:bg": "forever stop dist/src/index.js",
    "restart:bg": "forever restart dist/src/index.js",
    "list:bg": "forever list",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsc && node dist/scripts/migrate.js",
    "clear-old-mem": "tsc && node dist/scripts/clear-old-memory.js",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  }
}
